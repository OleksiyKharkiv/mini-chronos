<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                            https://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.27.xsd">

    <!-- ================================================================
         ChangeSet 003-1 : Table PROJECTS
         Parallel in Chronos: Vorgang / Kundenprojekt
         A project groups multiple orders for the same customer event.
         Example: "Jahreskonferenz 2026" → 3 rental orders on different dates
         ================================================================ -->
    <changeSet id="003-1-create-table-projects" author="oleksiy">
        <comment>Create projects table — Vorgänge per Kunde, groups rental orders</comment>

        <createTable tableName="projects">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" primaryKeyName="pk_projects" nullable="false"/>
            </column>
            <column name="customer_id" type="BIGINT">
                <constraints nullable="false"
                             foreignKeyName="fk_projects_customer"
                             references="customers(id)"/>
            </column>
            <!-- Who created this project — for audit/responsibility -->
            <column name="created_by_user_id" type="BIGINT">
                <constraints nullable="true"
                             foreignKeyName="fk_projects_created_by"
                             references="users(id)"/>
            </column>
            <column name="name" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="description" type="TEXT"/>
            <!-- Status lifecycle: ACTIVE → COMPLETED → CANCELLED -->
            <column name="status" type="VARCHAR(20)" defaultValue="ACTIVE">
                <constraints nullable="false"/>
            </column>
            <column name="start_date" type="DATE"/>
            <column name="end_date" type="DATE"/>
            <!-- Audit fields -->
            <column name="created_at" type="TIMESTAMP WITH TIME ZONE" defaultValueComputed="NOW()">
                <constraints nullable="false"/>
            </column>
            <column name="updated_at" type="TIMESTAMP WITH TIME ZONE" defaultValueComputed="NOW()">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <!-- Most common query: "show all projects for customer X" -->
        <createIndex tableName="projects" indexName="idx_projects_customer_id">
            <column name="customer_id"/>
        </createIndex>

        <!-- Filter by status — dashboard shows only ACTIVE projects -->
        <createIndex tableName="projects" indexName="idx_projects_status">
            <column name="status"/>
        </createIndex>

        <!-- Date-range queries for calendar views -->
        <createIndex tableName="projects" indexName="idx_projects_dates">
            <column name="start_date"/>
            <column name="end_date"/>
        </createIndex>

        <rollback>
            <dropIndex tableName="projects" indexName="idx_projects_dates"/>
            <dropIndex tableName="projects" indexName="idx_projects_status"/>
            <dropIndex tableName="projects" indexName="idx_projects_customer_id"/>
            <dropTable tableName="projects"/>
        </rollback>
    </changeSet>

    <!-- ================================================================
         ChangeSet 003-2 : CHECK constraint on project status
         Enforce valid lifecycle values at DB level — defense in depth.
         ================================================================ -->
    <changeSet id="003-2-projects-status-check" author="oleksiy">
        <comment>Add CHECK constraint to enforce valid project status values</comment>

        <sql>
            ALTER TABLE projects
                ADD CONSTRAINT chk_projects_status
                    CHECK (status IN ('ACTIVE', 'COMPLETED', 'CANCELLED'));
        </sql>

        <rollback>
            <sql>ALTER TABLE projects DROP CONSTRAINT chk_projects_status;</sql>
        </rollback>
    </changeSet>

    <!-- ================================================================
         ChangeSet 003-3 : Seed sample projects
         Linked to seed customers from migration 002
         ================================================================ -->
    <changeSet id="003-3-seed-sample-projects" author="oleksiy">

        <preConditions onFail="MARK_RAN">
            <sqlCheck expectedResult="0">SELECT COUNT(*)
                                         FROM projects</sqlCheck>
        </preConditions>

        <insert tableName="projects">
            <column name="customer_id"
                    valueComputed="(SELECT id FROM customers WHERE email = 't.bremer@koelnmesse.de')"/>
            <column name="name" value="Jahreskonferenz NRW 2026"/>
            <column name="status" value="ACTIVE"/>
            <column name="start_date" valueDate="2026-04-13"/>
            <column name="end_date" valueDate="2026-04-14"/>
        </insert>

        <insert tableName="projects">
            <column name="customer_id"
                    valueComputed="(SELECT id FROM customers WHERE email = 's.vogel@eventpro-duesseldorf.de')"/>
            <column name="name" value="Produktlaunch Event Mai 2026"/>
            <column name="status" value="ACTIVE"/>
            <column name="start_date" valueDate="2026-05-10"/>
            <column name="end_date" valueDate="2026-05-11"/>
        </insert>

        <rollback>
            <delete tableName="projects">
                <where>name IN ('Jahreskonferenz NRW 2026', 'Produktlaunch Event Mai 2026')</where>
            </delete>
        </rollback>
    </changeSet>

</databaseChangeLog>
