<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                            https://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.27.xsd">

    <!-- ================================================================
         ChangeSet 004-1 : Table EQUIPMENT_UNITS
         Parallel in Chronos: Artikel / Geräteverwaltung
         Represents individual physical items available for rent.
         In Lang GmbH context: projectors, lighting, sound, staging equipment.
         Note: In real Chronos this table has 300.000+ rows — indexes matter!
         ================================================================ -->
    <changeSet id="004-1-create-table-equipment-units" author="oleksiy">
        <comment>Create equipment_units table — physical rental items (Artikel/Geräte)</comment>

        <createTable tableName="equipment_units">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" primaryKeyName="pk_equipment_units" nullable="false"/>
            </column>
            <!-- SKU = Artikelnummer — unique business identifier (e.g. "PROJ-EPSON-EB-L1755U-001") -->
            <column name="sku" type="VARCHAR(100)">
                <constraints nullable="false" unique="true" uniqueConstraintName="uq_equipment_sku"/>
            </column>
            <column name="name" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <!-- Category for filtering: PROJECTOR, AUDIO, LIGHTING, STAGING, VIDEO, OTHER -->
            <column name="type" type="VARCHAR(50)">
                <constraints nullable="false"/>
            </column>
            <!-- Manufacturer + model for technical details -->
            <column name="manufacturer" type="VARCHAR(100)"/>
            <column name="model" type="VARCHAR(100)"/>
            <!-- Serial number — for physical tracking and service records -->
            <column name="serial_number" type="VARCHAR(100)">
                <constraints unique="true" uniqueConstraintName="uq_equipment_serial"/>
            </column>
            <!-- Current operational status -->
            <column name="status" type="VARCHAR(20)" defaultValue="AVAILABLE">
                <constraints nullable="false"/>
            </column>
            <!-- Pricing -->
            <column name="daily_rate" type="DECIMAL(10,2)">
                <constraints nullable="false"/>
            </column>
            <!-- Optional: purchase price for asset tracking -->
            <column name="purchase_price" type="DECIMAL(10,2)"/>
            <column name="purchase_date" type="DATE"/>
            <!-- Location in warehouse: Lager A, Regal 3 -->
            <column name="storage_location" type="VARCHAR(100)"/>
            <column name="notes" type="TEXT"/>
            <!-- Soft delete — never delete equipment with order history -->
            <column name="active" type="BOOLEAN" defaultValueBoolean="true">
                <constraints nullable="false"/>
            </column>
            <!-- Audit -->
            <column name="created_at" type="TIMESTAMP WITH TIME ZONE" defaultValueComputed="NOW()">
                <constraints nullable="false"/>
            </column>
            <column name="updated_at" type="TIMESTAMP WITH TIME ZONE" defaultValueComputed="NOW()">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <!-- Filter by type — most common query: "show all available projectors" -->
        <createIndex tableName="equipment_units" indexName="idx_equipment_type">
            <column name="type"/>
        </createIndex>

        <!-- Filter available items fast -->
        <createIndex tableName="equipment_units" indexName="idx_equipment_status">
            <column name="status"/>
        </createIndex>

        <!-- Combined: type + status — the Verfügbarkeitsprüfung query -->
        <createIndex tableName="equipment_units" indexName="idx_equipment_type_status">
            <column name="type"/>
            <column name="status"/>
        </createIndex>

        <rollback>
            <dropIndex tableName="equipment_units" indexName="idx_equipment_type_status"/>
            <dropIndex tableName="equipment_units" indexName="idx_equipment_status"/>
            <dropIndex tableName="equipment_units" indexName="idx_equipment_type"/>
            <dropTable tableName="equipment_units"/>
        </rollback>
    </changeSet>

    <!-- ================================================================
         ChangeSet 004-2 : CHECK constraints on equipment status and type
         ================================================================ -->
    <changeSet id="004-2-equipment-check-constraints" author="oleksiy">
        <comment>Enforce valid status and type values via CHECK constraints</comment>

        <sql>
            ALTER TABLE equipment_units
                ADD CONSTRAINT chk_equipment_status
                    CHECK (status IN ('AVAILABLE', 'RENTED', 'MAINTENANCE', 'RETIRED'));

            ALTER TABLE equipment_units
                ADD CONSTRAINT chk_equipment_type
                    CHECK (type IN ('PROJECTOR', 'AUDIO', 'LIGHTING', 'STAGING', 'VIDEO', 'LED_WALL', 'OTHER'));
        </sql>

        <rollback>
            <sql>
                ALTER TABLE equipment_units DROP CONSTRAINT chk_equipment_type;
                ALTER TABLE equipment_units DROP CONSTRAINT chk_equipment_status;
            </sql>
        </rollback>
    </changeSet>

