<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                            https://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.27.xsd">

    <!-- ================================================================
         ChangeSet 002-1 : Table CUSTOMERS
         Parallel in Chronos: Stammdaten → Kunden
         In Lang GmbH context: B2B clients (Firmen, Veranstalter)
         ================================================================ -->
    <changeSet id="002-1-create-table-customers" author="oleksiy">
        <comment>Create customers table — Stammdatenverwaltung for B2B clients</comment>

        <createTable tableName="customers">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" primaryKeyName="pk_customers" nullable="false"/>
            </column>
            <column name="name" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="email" type="VARCHAR(255)">
                <constraints nullable="false" unique="true" uniqueConstraintName="uq_customers_email"/>
            </column>
            <column name="phone" type="VARCHAR(50)"/>
            <!-- Company data — important for B2B ERP invoicing -->
            <column name="company_name" type="VARCHAR(255)"/>
            <column name="tax_id" type="VARCHAR(50)">
                <constraints uniqueConstraintName="uq_customers_tax_id" unique="true"/>
            </column>
            <!-- Billing address -->
            <column name="street" type="VARCHAR(255)"/>
            <column name="city" type="VARCHAR(100)"/>
            <column name="postal_code" type="VARCHAR(20)"/>
            <column name="country" type="VARCHAR(100)" defaultValue="Deutschland"/>
            <!-- Soft delete — never hard-delete customers with order history -->
            <column name="active" type="BOOLEAN" defaultValueBoolean="true">
                <constraints nullable="false"/>
            </column>
            <!-- Audit fields -->
            <column name="created_at" type="TIMESTAMP WITH TIME ZONE" defaultValueComputed="NOW()">
                <constraints nullable="false"/>
            </column>
            <column name="updated_at" type="TIMESTAMP WITH TIME ZONE" defaultValueComputed="NOW()">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <!-- Full-text search support on name — critical for 10k+ customer lists -->
        <createIndex tableName="customers" indexName="idx_customers_name">
            <column name="name"/>
        </createIndex>

        <!-- Filter active customers fast -->
        <createIndex tableName="customers" indexName="idx_customers_active">
            <column name="active"/>
        </createIndex>

        <rollback>
            <dropIndex tableName="customers" indexName="idx_customers_active"/>
            <dropIndex tableName="customers" indexName="idx_customers_name"/>
            <dropTable tableName="customers"/>
        </rollback>
    </changeSet>

    <!-- ================================================================
