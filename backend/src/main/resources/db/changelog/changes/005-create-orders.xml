<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                            https://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.27.xsd">

    <!-- ================================================================
         ChangeSet 005-1 : Table ORDERS
         Parallel in Chronos: Auftrag / Mietjob
         Central business entity. One Project → many Orders.
         KEY DESIGN: @Version field for Optimistic Locking —
         prevents double-booking when 2 users edit same order concurrently.
         ================================================================ -->
    <changeSet id="005-1-create-table-orders" author="oleksiy">
        <comment>Create orders table — Aufträge mit Optimistic Locking (@Version)</comment>

        <createTable tableName="orders">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" primaryKeyName="pk_orders" nullable="false"/>
            </column>
            <column name="project_id" type="BIGINT">
                <constraints nullable="false"
                             foreignKeyName="fk_orders_project"
                             references="projects(id)"/>
            </column>
            <!-- Who created this order -->
            <column name="created_by_user_id" type="BIGINT">
                <constraints nullable="true"
                             foreignKeyName="fk_orders_created_by"
                             references="users(id)"/>
            </column>
            <!-- Human-readable order number: ORD-2026-00042 -->
            <column name="order_number" type="VARCHAR(50)">
                <constraints nullable="false" unique="true" uniqueConstraintName="uq_orders_number"/>
            </column>
            <!-- Status lifecycle: DRAFT → CONFIRMED → IN_PROGRESS → COMPLETED → INVOICED → CANCELLED -->
            <column name="status" type="VARCHAR(20)" defaultValue="DRAFT">
                <constraints nullable="false"/>
            </column>
            <!-- Rental period for the whole order (can differ per item in real ERP, simplified here) -->
            <column name="start_date" type="DATE">
                <constraints nullable="false"/>
            </column>
            <column name="end_date" type="DATE">
                <constraints nullable="false"/>
            </column>
            <!-- Financial summary — denormalized for performance, recalculated on save -->
            <column name="total_amount" type="DECIMAL(10,2)" defaultValueNumeric="0.00">
                <constraints nullable="false"/>
            </column>
            <column name="discount_percent" type="DECIMAL(5,2)" defaultValueNumeric="0.00"/>
            <column name="notes" type="TEXT"/>
            <!-- *** OPTIMISTIC LOCKING FIELD ***
                 Hibernate @Version annotation maps to this column.
                 On UPDATE: WHERE id = ? AND version = ?
                 If version mismatch → OptimisticLockException → 409 Conflict
                 Prevents concurrent edits from overwriting each other silently. -->
            <column name="version" type="BIGINT" defaultValueNumeric="0">
                <constraints nullable="false"/>
            </column>
            <!-- Audit -->
            <column name="created_at" type="TIMESTAMP WITH TIME ZONE" defaultValueComputed="NOW()">
                <constraints nullable="false"/>
            </column>
            <column name="updated_at" type="TIMESTAMP WITH TIME ZONE" defaultValueComputed="NOW()">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <!-- Most common: all orders for a project -->
        <createIndex tableName="orders" indexName="idx_orders_project_id">
            <column name="project_id"/>
        </createIndex>

        <!-- Dashboard: all orders in DRAFT or CONFIRMED status -->
        <createIndex tableName="orders" indexName="idx_orders_status">
            <column name="status"/>
        </createIndex>

        <!-- Date range queries: orders overlapping a given period -->
        <createIndex tableName="orders" indexName="idx_orders_dates">
            <column name="start_date"/>
            <column name="end_date"/>
        </createIndex>

        <rollback>
            <dropIndex tableName="orders" indexName="idx_orders_dates"/>
            <dropIndex tableName="orders" indexName="idx_orders_status"/>
            <dropIndex tableName="orders" indexName="idx_orders_project_id"/>
            <dropTable tableName="orders"/>
        </rollback>
    </changeSet>

    <!-- ================================================================
         ChangeSet 005-2 : CHECK constraints on orders
         ================================================================ -->
    <changeSet id="005-2-orders-check-constraints" author="oleksiy">
        <comment>Enforce valid order status and date logic at DB level</comment>

        <sql>
            ALTER TABLE orders
                ADD CONSTRAINT chk_orders_status
                    CHECK (status IN ('DRAFT','CONFIRMED','IN_PROGRESS','COMPLETED','INVOICED','CANCELLED'));

            ALTER TABLE orders
                ADD CONSTRAINT chk_orders_dates
                    CHECK (end_date >= start_date);

            ALTER TABLE orders
                ADD CONSTRAINT chk_orders_amount
                    CHECK (total_amount >= 0);
        </sql>

        <rollback>
            <sql>
                ALTER TABLE orders DROP CONSTRAINT chk_orders_amount;
                ALTER TABLE orders DROP CONSTRAINT chk_orders_dates;
                ALTER TABLE orders DROP CONSTRAINT chk_orders_status;
            </sql>
        </rollback>
    </changeSet>

    <!-- ================================================================
         ChangeSet 005-3 : Table ORDER_ITEMS
         Parallel in Chronos: Auftragsposition / Mietposition
         Each item = one equipment unit rented within the order period.
         @ManyToOne → Order (with cascade)
         @ManyToOne → EquipmentUnit (no cascade — master data)
         ================================================================ -->
    <changeSet id="005-3-create-table-order-items" author="oleksiy">
        <comment>Create order_items table — Auftragspositionen, links orders to equipment</comment>

        <createTable tableName="order_items">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" primaryKeyName="pk_order_items" nullable="false"/>
            </column>
            <column name="order_id" type="BIGINT">
                <constraints nullable="false"
                             foreignKeyName="fk_order_items_order"
                             references="orders(id)"/>
            </column>
            <column name="equipment_id" type="BIGINT">
                <constraints nullable="false"
                             foreignKeyName="fk_order_items_equipment"
                             references="equipment_units(id)"/>
            </column>
            <!-- Quantity: usually 1 for serialized equipment, can be >1 for consumables -->
            <column name="quantity" type="INT" defaultValueNumeric="1">
                <constraints nullable="false"/>
            </column>
            <!-- Price snapshotted at time of order — important! Price may change later -->
            <column name="unit_price" type="DECIMAL(10,2)">
                <constraints nullable="false"/>
            </column>
            <!-- Computed: quantity * unit_price * rental_days -->
            <column name="line_total" type="DECIMAL(10,2)">
                <constraints nullable="false"/>
            </column>
            <column name="notes" type="TEXT"/>
            <column name="created_at" type="TIMESTAMP WITH TIME ZONE" defaultValueComputed="NOW()">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <!-- Main lookup: all items for an order (cascade load) -->
        <createIndex tableName="order_items" indexName="idx_order_items_order_id">
            <column name="order_id"/>
        </createIndex>

        <!-- Reverse lookup: all orders containing specific equipment -->
        <createIndex tableName="order_items" indexName="idx_order_items_equipment_id">
            <column name="equipment_id"/>
        </createIndex>

        <rollback>
            <dropIndex tableName="order_items" indexName="idx_order_items_equipment_id"/>
            <dropIndex tableName="order_items" indexName="idx_order_items_order_id"/>
            <dropTable tableName="order_items"/>
        </rollback>
    </changeSet>

    <!-- ================================================================
         ChangeSet 005-4 : CHECK constraints on order_items
         ================================================================ -->
    <changeSet id="005-4-order-items-check-constraints" author="oleksiy">
        <comment>Enforce positive quantity and price values</comment>

        <sql>
            ALTER TABLE order_items
                ADD CONSTRAINT chk_order_items_quantity CHECK (quantity > 0);

            ALTER TABLE order_items
                ADD CONSTRAINT chk_order_items_price CHECK (unit_price >= 0);

            ALTER TABLE order_items
                ADD CONSTRAINT chk_order_items_total CHECK (line_total >= 0);
        </sql>

        <rollback>
            <sql>
                ALTER TABLE order_items DROP CONSTRAINT chk_order_items_total;
                ALTER TABLE order_items DROP CONSTRAINT chk_order_items_price;
                ALTER TABLE order_items DROP CONSTRAINT chk_order_items_quantity;
            </sql>
        </rollback>
    </changeSet>

</databaseChangeLog>
