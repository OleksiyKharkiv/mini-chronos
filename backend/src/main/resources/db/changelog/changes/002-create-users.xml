<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        https://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <!--
        CHANGESET: создание таблицы users.

        Таблица users создаётся первой потому что roles ссылается на неё (FK).
        Нет никаких входящих FK — users ни от чего не зависит.

        СООТВЕТСТВИЕ МЕЖДУ ENTITY И ТАБЛИЦЕЙ:
        User.java поле          → колонка в таблице
        ─────────────────────────────────────────
        id (BaseEntity)         → id BIGINT PK
        createdAt (BaseEntity)  → created_at TIMESTAMP
        updatedAt (BaseEntity)  → updated_at TIMESTAMP
        userName                → username VARCHAR(100)
        email                   → email VARCHAR(255)
        passwordHash            → password_hash VARCHAR(255)
        firstName               → first_name VARCHAR(100)
        lastName                → last_name VARCHAR(100)
        active                  → active BOOLEAN

        ВАЖНО: имена колонок в snake_case (username, created_at),
        имена полей в Java в camelCase (userName, createdAt).
        Hibernate автоматически конвертирует camelCase → snake_case
        по умолчанию (стратегия SpringPhysicalNamingStrategy).
        Поэтому в @Column(name = "...") часто не нужно явно писать имя,
        но явное указание — лучшая практика для читаемости.
    -->

    <changeSet id="002-create-users-table" author="dev">

        <preConditions onFail="MARK_RAN">
            <not>
                <tableExists tableName="users"/>
            </not>
        </preConditions>

        <createTable tableName="users"
                     remarks="System users — employees of the company using mini-chronos">

            <!--
                BIGINT для ID: соответствует Long в Java.
                autoIncrement="false": мы используем Sequence, не SERIAL.
                nullable="false" + primaryKey="true" = NOT NULL PRIMARY KEY.
            -->
            <column name="id" type="BIGINT" remarks="Primary key, generated by default_sequence">
                <constraints nullable="false" primaryKey="true" primaryKeyName="pk_users"/>
            </column>

            <!--
                created_at / updated_at: заполняются автоматически через
                @CreatedDate / @LastModifiedDate (AuditingEntityListener).
                defaultValueComputed="NOW()": если запись создаётся в обход JPA (например,
                SQL-скрипт или liquibase seed), PostgreSQL сам подставит текущее время.
                Двойная защита: JPA + DB default.
            -->
            <column name="created_at" type="TIMESTAMP WITHOUT TIME ZONE"
                    remarks="Audit: when the record was created">
                <constraints nullable="false"/>
            </column>

            <column name="updated_at" type="TIMESTAMP WITHOUT TIME ZONE"
                    remarks="Audit: when the record was last modified">
                <constraints nullable="false"/>
            </column>

            <column name="username" type="VARCHAR(100)"
                    remarks="Login name, unique across the system">
                <constraints nullable="false" unique="true" uniqueConstraintName="uq_users_username"/>
            </column>

            <column name="email" type="VARCHAR(255)"
                    remarks="Email address, used for notifications and login recovery">
                <constraints nullable="false" unique="true" uniqueConstraintName="uq_users_email"/>
            </column>

            <!--
                VARCHAR(255) для BCrypt hash: BCrypt всегда 60 символов.
                255 — стандартный запас на случай смены алгоритма хеширования в будущем.
                НИКОГДА не храни пароли в plaintext. Только hash.
            -->
            <column name="password_hash" type="VARCHAR(255)"
                    remarks="BCrypt hashed password — NEVER store plaintext">
                <constraints nullable="false"/>
            </column>

            <column name="first_name" type="VARCHAR(100)">
                <constraints nullable="false"/>
            </column>

            <column name="last_name" type="VARCHAR(100)">
                <constraints nullable="false"/>
            </column>

            <!--
                defaultValueBoolean="true": новый пользователь активен по умолчанию.
                Соответствует: private boolean active = true; в User.java.
                Двойная синхронизация: JPA default + DB default.
            -->
            <column name="active" type="BOOLEAN" defaultValueBoolean="true"
                    remarks="Soft-delete flag: false = deactivated, record preserved for audit">
                <constraints nullable="false"/>
            </column>

        </createTable>

        <!-- ИНДЕКСЫ: создаются отдельными тегами после createTable -->

        <!--
            idx_user_active: для запроса "все активные пользователи".
            Partial index был бы эффективнее (WHERE active = true),
            но Liquibase не поддерживает partial index нативно.
            Для MVP обычного индекса достаточно.
        -->
        <createIndex tableName="users"
                     indexName="idx_user_active">
            <column name="active"/>
        </createIndex>

        <rollback>
            <dropTable tableName="users"/>
        </rollback>

    </changeSet>

</databaseChangeLog>