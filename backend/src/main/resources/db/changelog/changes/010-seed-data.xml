    <!-- SEQUENCE SYNC: синхронизация sequence после ручной вставки данных  -->
    <!-- ═══════════════════════════════════════════════════════════════════ -->

    <changeSet id="010-sync-sequence" author="dev" context="dev,test">
        <!--
            КРИТИЧЕСКИ ВАЖНО при ручной вставке с фиксированными ID!

            Мы вставили записи с id: 1,2,3, 10,11,12, 100,101, 200..220, 300, 400, 500..502, 600..610.
            Максимальный ID = 610.

            Если sequence сейчас на значении 1 (первый старт), то:
              Hibernate вызовет nextval() → получит 1
              Попытается INSERT с id=1 → ОШИБКА: "duplicate key violates unique constraint"

            Решение: сдвинуть sequence выше всех существующих ID.
            setval(sequence, 700, true):
              700 — новое значение (выше 610 с запасом, кратно allocationSize=50 для чистоты)
              true — следующий nextval() вернёт 701 (не 700)

            Это стандартная операция при любом seed с фиксированными ID.
        -->
        <sql>
            SELECT setval('default_sequence', 700, true);
        </sql>

        <rollback>
            <!-- Rollback sequence практически бессмысленен, но Liquibase требует явного rollback -->
            <sql>SELECT setval('default_sequence', 1, false);</sql>
        </rollback>

    </changeSet>

